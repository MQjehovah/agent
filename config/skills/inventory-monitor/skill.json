{
    "name": "inventory-monitor",
    "description": "库存监控专家，实时监控库存状态并发出预警",
    "version": "1.0.0",
    "author": "system",
    "tags": ["库存", "监控", "预警"],
    "enabled": true,
    "tools": [
        {
            "name": "execute_query",
            "description": "查询库存数据"
        },
        {
            "name": "send_email",
            "description": "发送库存预警邮件"
        }
    ],
    "variables": [
        {
            "name": "warning_threshold",
            "description": "库存预警阈值（天）",
            "default": "7",
            "required": false
        },
        {
            "name": "alert_recipients",
            "description": "预警接收人",
            "default": "",
            "required": false
        }
    ],
    "output_format": "markdown"
}