{
    "name": "report-writer",
    "description": "专业报告撰写助手，生成结构化的业务报告",
    "version": "1.0.0",
    "author": "system",
    "tags": ["报告", "写作", "文档"],
    "enabled": true,
    "tools": [
        {
            "name": "send_email",
            "description": "发送报告邮件"
        }
    ],
    "variables": [
        {
            "name": "report_type",
            "description": "报告类型：daily/weekly/monthly",
            "default": "daily",
            "required": false
        },
        {
            "name": "recipients",
            "description": "收件人邮箱列表",
            "default": "",
            "required": false
        }
    ],
    "output_format": "markdown"
}