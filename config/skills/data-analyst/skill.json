{
    "name": "data-analyst",
    "description": "数据分析专家，擅长从数据库查询数据并生成深度分析报告",
    "version": "1.0.0",
    "author": "system",
    "tags": ["数据分析", "报告", "SQL"],
    "enabled": true,
    "tools": [
        {
            "name": "execute_query",
            "description": "执行SQL查询获取数据"
        },
        {
            "name": "list_tables",
            "description": "列出数据库中的表"
        },
        {
            "name": "describe_table",
            "description": "获取表结构信息"
        }
    ],
    "variables": [
        {
            "name": "analysis_type",
            "description": "分析类型：sales/inventory/financial/production",
            "default": "sales",
            "required": false
        },
        {
            "name": "time_range",
            "description": "时间范围",
            "default": "本月",
            "required": false
        }
    ],
    "output_format": "markdown"
}