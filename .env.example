# ===========================================
# Agent 系统配置文件
# 复制此文件为 .env 并填入实际值
# ===========================================

# ----- LLM 配置 (必需) -----
# 配置文件为 config/llm_endpoints.json（JSON 数组，每元素包含 model/base_url/api_key）
# 复制 config/llm_endpoints.example.json 为 config/llm_endpoints.json 并填入实际值
# 支持多端点：按数组顺序依次尝试，失败自动切换下一个
# 单端点用一个元素的数组即可

# ----- 会话配置 (可选) -----
# 会话过期时间（秒），默认 1 小时
SESSION_TTL_SECONDS=3600

# 最大会话数量，默认 100
MAX_SESSIONS=100

# ----- 缓存配置 (可选) -----
# 缓存最大条目数
CACHE_MAX_SIZE=1000

# 缓存过期时间（秒）
CACHE_TTL_SECONDS=3600

# ----- 日志配置 (可选) -----
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ----- IT运维系统凭据 (从子代理 PROMPT.md 引用) -----
# IT系统通用账号（LDAP），默认 s_software
IT_SYSTEM_USERNAME=s_software
# IT系统通用密码（Gitlab/Gerrit/Jenkins/Jira），请替换为实际密码
IT_SYSTEM_PASSWORD=your-it-password-here

# ----- 搜索配置 (可选) -----
# 搜索后端优先级（逗号分隔），默认自动根据已配置的 API Key 排序
# 可用值: tavily, serper, bing, searxng, duckduckgo, duckduckgo_api
# 不配置则按以下顺序自动选择: tavily > serper > bing > searxng > duckduckgo
# SEARCH_BACKENDS=tavily,searxng,duckduckgo

# Tavily 搜索 API（免费 1000 次/月，专为 AI Agent 设计）
# 注册: https://tavily.com
# TAVILY_API_KEY=tvly-xxxxx

# Serper 搜索 API（免费 2500 次/月，返回 Google 搜索结果）
# 注册: https://serper.dev
# SERPER_API_KEY=xxxxx

# Bing Web Search API（微软官方，付费但便宜）
# 注册: https://portal.azure.com → Bing Search v7
# BING_SEARCH_API_KEY=xxxxx

# SearXNG 自建搜索引擎（免费无限调用，需 Docker 部署）
# Docker 部署: docker run -d -p 8888:8080 searxng/searxng
# SEARXNG_URL=http://localhost:8888
# SEARXNG_ENGINES=google,bing,duckduckgo
# SEARXNG_TIMEOUT=10

# ----- 自学习配置 (可选) -----
# 每轮任务反思（任务完成后自动提取经验），默认关闭
# 启用后每次任务结束会在后台调用 LLM 进行反思，产生额外 API 开销
LEARNING_PER_ROUND=false

# ----- 自主模式配置 (可选) -----
# 自主巡检间隔（秒），默认 1800（30 分钟）
AUTONOMOUS_DISCOVERY_INTERVAL=1800

# ----- RAG 知识库配置 (可选) -----
# RAG 服务地址（配置后 agent 将获得 knowledge_search 工具）
# RAG_BASE_URL=https://your-rag-server
# RAG 认证方式一：用户名密码登录（推荐，自动管理 Token 刷新）
# RAG_USERNAME=admin
# RAG_PASSWORD=123456
# RAG 认证方式二：直接提供 JWT Token（可选，优先级低于用户名密码）
# RAG_TOKEN=your-rag-token-here