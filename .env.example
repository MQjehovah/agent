# ===========================================
# Agent 系统配置文件
# 复制此文件为 .env 并填入实际值
# ===========================================

# API 地址，根据使用的服务配置
# 智谱 GLM: https://coding.dashscope.aliyuncs.com/v1
# OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# API 密钥，从 LLM 提供商获取
OPENAI_API_KEY=your-api-key-here

# ----- LLM 配置 (必需) -----
# 模型名称 (如 glm-5, gpt-4o, deepseek-chat 等)
MODEL_NAME=glm-5

# LLM 请求超时（秒），默认 300（5 分钟）
LLM_TIMEOUT=300

# LLM 连接超时（秒），默认 30
LLM_CONNECT_TIMEOUT=30

# ----- MCP 服务配置 (可选) -----
# 设备运维 API 地址
DEVICE_API_BASE_URL=https://bms-cn.rosiwit.com

# WebSocket 终端地址
WS_BASE_URL=wss://dev.xzrobot.com:10000

# ----- 会话配置 (可选) -----
# 会话过期时间（秒），默认 1 小时
SESSION_TTL_SECONDS=3600

# 最大会话数量，默认 100
MAX_SESSIONS=100

# ----- 缓存配置 (可选) -----
# 缓存最大条目数
CACHE_MAX_SIZE=1000

# 缓存过期时间（秒）
CACHE_TTL_SECONDS=3600

# ----- 日志配置 (可选) -----
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ----- IT运维系统凭据 (从子代理 PROMPT.md 引用) -----
# IT系统通用账号（LDAP），默认 s_software
IT_SYSTEM_USERNAME=s_software
# IT系统通用密码（Gitlab/Gerrit/Jenkins/Jira），请替换为实际密码
IT_SYSTEM_PASSWORD=your-it-password-here

# ----- 搜索配置 (可选) -----
# 搜索后端优先级（逗号分隔），默认自动根据已配置的 API Key 排序
# 可用值: tavily, serper, bing, searxng, duckduckgo, duckduckgo_api
# 不配置则按以下顺序自动选择: tavily > serper > bing > searxng > duckduckgo
# SEARCH_BACKENDS=tavily,searxng,duckduckgo

# Tavily 搜索 API（免费 1000 次/月，专为 AI Agent 设计）
# 注册: https://tavily.com
# TAVILY_API_KEY=tvly-xxxxx

# Serper 搜索 API（免费 2500 次/月，返回 Google 搜索结果）
# 注册: https://serper.dev
# SERPER_API_KEY=xxxxx

# Bing Web Search API（微软官方，付费但便宜）
# 注册: https://portal.azure.com → Bing Search v7
# BING_SEARCH_API_KEY=xxxxx

# SearXNG 自建搜索引擎（免费无限调用，需 Docker 部署）
# Docker 部署: docker run -d -p 8888:8080 searxng/searxng
# SEARXNG_URL=http://localhost:8888
# SEARXNG_ENGINES=google,bing,duckduckgo
# SEARXNG_TIMEOUT=10

# ----- 自主模式配置 (可选) -----
# 自主巡检间隔（秒），默认 1800（30 分钟）
AUTONOMOUS_DISCOVERY_INTERVAL=1800